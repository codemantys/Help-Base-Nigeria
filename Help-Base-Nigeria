    // =============================================
    // LOAD COMPANIES BY CATEGORY
    // =============================================
    async function loadCompaniesByCategory(category) {
        const container = document.getElementById('companies-container');
        container.innerHTML = '<div class="news-loading"><i class="fa-solid fa-circle-notch fa-spin"></i><p>Loading companies...</p></div>';
       
        // Hide any previous index error
        document.getElementById('index-error-banner').classList.add('hidden');
       
        try {
            // First, try to get from Firebase WITHOUT orderBy to avoid index requirement
            // This will work even without an index
            const snapshot = await db.collection('companies')
                .where('category', '==', category)
                .get();
           
            if (!snapshot.empty) {
                // Convert to array and sort manually in JavaScript
                const companies = [];
                snapshot.forEach(doc => {
                    companies.push({ id: doc.id, ...doc.data() });
                });
               
                // Sort by name manually
                companies.sort((a, b) => a.name.localeCompare(b.name));
               
                let html = '';
                companies.forEach(company => {
                    const phoneCount = company.phones?.length || 0;
                    const logo = company.logo || '';
                   
                    html += `
                        <div class="company-card" onclick="showCompanyDetail('${company.id}')">
                            <div class="company-logo">
                                ${logo ?
                                    `<img src="${logo}" alt="${company.name}">` :
                                    `<i class="fa-solid fa-building"></i>`
                                }
                            </div>
                            <div class="company-info">
                                <h3>${company.name}</h3>
                                <p><i class="fa-solid fa-phone"></i> ${phoneCount} contact numbers</p>
                            </div>
                            <i class="fa-solid fa-chevron-right" style="color: var(--grey);"></i>
                        </div>
                    `;
                });
                container.innerHTML = html;
               
                // Update connection status
                document.getElementById('connection-status').innerHTML = '<i class="fa-solid fa-circle"></i> Connected';
                document.getElementById('connection-status').className = 'connection-status status-connected';
               
            } else {
                // No data in Firebase - use mock data
                useMockCompanies(category);
            }
        } catch (error) {
            console.error('Error loading companies:', error);
           
            // Check if it's an index error
            if (error.message && error.message.includes('index')) {
                // Extract index creation URL from error
                const match = error.message.match(/https:\/\/console\.firebase\.google\.com[^\s]*/);
                if (match) {
                    indexUrl = match[0];
                    document.getElementById('create-index-link').href = indexUrl;
                    document.getElementById('index-error-banner').classList.remove('hidden');
                }
               
                // Still show mock data
                useMockCompanies(category);
               
                // Update connection status
                document.getElementById('connection-status').innerHTML = '<i class="fa-solid fa-circle-exclamation"></i> Index Required';
                document.getElementById('connection-status').className = 'connection-status status-warning';
            } else {
                // Some other error, still show mock data
                useMockCompanies(category);
            }
        }
    }

    function useMockCompanies(category) {
        const container = document.getElementById('companies-container');
        const mockCompaniesInCategory = mockCompanies[category] || [];
       
        if (mockCompaniesInCategory.length === 0) {
            container.innerHTML = `
                <div class="news-empty">
                    <i class="fa-regular fa-building" style="font-size: 2rem; margin-bottom: 10px;"></i>
                    <p>No companies found in this category yet.</p>
                </div>
            `;
            return;
        }
       
        let html = '';
        mockCompaniesInCategory.forEach(company => {
            const phoneCount = company.phones?.length || 0;
           
            html += `
                <div class="company-card" onclick="showCompanyDetail('${company.id}')">
                    <div class="company-logo">
                        <i class="fa-solid fa-building"></i>
                    </div>
                    <div class="company-info">
                        <h3>${company.name}</h3>
                        <p><i class="fa-solid fa-phone"></i> ${phoneCount} contact numbers</p>
                    </div>
                    <i class="fa-solid fa-chevron-right" style="color: var(--grey);"></i>
                </div>
            `;
        });
        container.innerHTML = html;
    }

