    // =============================================
    // NEWS FUNCTIONS
    // =============================================
    async function loadNewsFromFirebase(reset = true) {
        const newsContainer = document.getElementById('news-container');
        const loadMoreBtn = document.getElementById('load-more-btn');
       
        if (reset) {
            newsContainer.innerHTML = '<div class="news-loading"><i class="fa-solid fa-circle-notch fa-spin"></i><p>Loading news...</p></div>';
            lastVisible = null;
            hasMoreNews = true;
        }
       
        if (loadingNews) return;
        loadingNews = true;
       
        if (!reset) {
            loadMoreBtn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Loading...';
            loadMoreBtn.disabled = true;
        }
       
        try {
            // Try to get news from Firebase without orderBy first to avoid index issues
            const snapshot = await db.collection('news')
                .limit(currentNewsCount)
                .get();
           
            if (!snapshot.empty) {
                // Convert to array and sort by publishedAt manually
                const news = [];
                snapshot.forEach(doc => {
                    news.push({ id: doc.id, ...doc.data() });
                });
               
                // Sort by publishedAt descending (most recent first)
                news.sort((a, b) => {
                    const dateA = a.publishedAt?.toDate ? a.publishedAt.toDate() : new Date(0);
                    const dateB = b.publishedAt?.toDate ? b.publishedAt.toDate() : new Date(0);
                    return dateB - dateA;
                });
               
                let newsHtml = '';
                news.forEach(item => {
                    const date = item.publishedAt?.toDate ? item.publishedAt.toDate() : new Date();
                    const timeAgo = getTimeAgo(date);
                   
                    newsHtml += `
                        <div class="news-item" onclick="openNewsArticle('${item.sourceUrl || '#'}')">
                            <div class="news-content">
                                <div class="news-meta">
                                    <span class="company-tag">${item.companyName || item.company || 'Company'}</span>
                                    <span class="time-ago">${timeAgo}</span>
                                </div>
                                <div class="news-title">${item.title || 'Untitled'}</div>
                                <div class="news-excerpt">
                                    ${item.excerpt || item.content?.substring(0, 100) + '...' || 'Click to read...'}
                                    <i class="fa-solid fa-arrow-right" style="color: var(--primary-green);"></i>
                                </div>
                            </div>
                            <div class="news-image" style="background-image: url('${item.imageUrl || 'https://via.placeholder.com/80?text=News'}')"></div>
                        </div>
                    `;
                });
               
                if (reset) {
                    newsContainer.innerHTML = newsHtml;
                } else {
                    newsContainer.insertAdjacentHTML('beforeend', newsHtml);
                }
               
                hasMoreNews = snapshot.docs.length === currentNewsCount;
            } else {
                // No news in Firebase - use mock news
                renderMockNews(reset);
            }
        } catch (error) {
            console.error('Error loading news:', error);
            // Fall back to mock news on error
            renderMockNews(reset);
        } finally {
            loadingNews = false;
            if (!reset) {
                loadMoreBtn.innerHTML = 'View More News';
                loadMoreBtn.disabled = false;
                if (!hasMoreNews) {
                    loadMoreBtn.innerHTML = 'No More News';
                    loadMoreBtn.disabled = true;
                }
            }
        }
    }

    function renderMockNews(reset = true) {
        const newsContainer = document.getElementById('news-container');
        const loadMoreBtn = document.getElementById('load-more-btn');
       
        let newsHtml = '';
        const newsToShow = mockNewsData.slice(0, currentNewsCount);
       
        newsToShow.forEach(item => {
            newsHtml += `
                <div class="news-item" onclick="openNewsArticle('${item.link}')">
                    <div class="news-content">
                        <div class="news-meta">
                            <span class="company-tag">${item.company}</span>
                            <span class="time-ago">${item.timeAgo}</span>
                        </div>
                        <div class="news-title">${item.title}</div>
                        <div class="news-excerpt">
                            ${item.excerpt}
                            <i class="fa-solid fa-arrow-right" style="color: var(--primary-green);"></i>
                        </div>
                    </div>
                    <div class="news-image" style="background-image: url('${item.imageUrl}')"></div>
                </div>
            `;
        });
       
        if (reset) {
            newsContainer.innerHTML = newsHtml;
        } else {
            newsContainer.insertAdjacentHTML('beforeend', newsHtml);
        }
       
        hasMoreNews = currentNewsCount < mockNewsData.length;
        loadMoreBtn.innerHTML = hasMoreNews ? 'View More News' : 'No More News';
        loadMoreBtn.disabled = !hasMoreNews;
    }

    function loadMoreNews() {
        if (!hasMoreNews) return;
        currentNewsCount += 3;
        loadNewsFromFirebase(false);
    }

    function getTimeAgo(date) {
        const seconds = Math.floor((new Date() - date) / 1000);
        if (seconds < 60) return 'just now';
        const minutes = Math.floor(seconds / 60);
        if (minutes < 60) return minutes + ' minutes ago';
        const hours = Math.floor(minutes / 60);
        if (hours < 24) return hours + ' hours ago';
        const days = Math.floor(hours / 24);
        if (days < 7) return days + ' days ago';
        return 'recently';
    }

    function openNewsArticle(url) {
        if (url && url !== '#') {
            window.open(url, '_blank');
        }
    }

    // =============================================
    // SEARCH FUNCTIONALITY
    // =============================================
    const searchInput = document.getElementById('main-search');
    const clearBtn = document.getElementById('clear-search');
    const homeView = document.getElementById('home-view');
    const searchView = document.getElementById('search-view');
    const headerLogo = document.getElementById('header-logo');

    searchInput.addEventListener('input', async (e) => {
        const val = e.target.value.toLowerCase();
        if (val.length > 0) {
            homeView.classList.add('hidden');
            searchView.classList.remove('hidden');
            headerLogo.classList.add('hidden');
            clearBtn.style.display = 'block';
            await performSearch(val);
        } else {
            resetSearch();
        }
    });

    clearBtn.addEventListener('click', () => {
        searchInput.value = '';
        resetSearch();
    });

    function resetSearch() {
        homeView.classList.remove('hidden');
        searchView.classList.add('hidden');
        headerLogo.classList.remove('hidden');
        clearBtn.style.display = 'none';
    }

    async function performSearch(query) {
        searchView.innerHTML = '<div class="news-loading"><i class="fa-solid fa-circle-notch fa-spin"></i><p>Searching...</p></div>';
       
        try {
            // Search in Firebase
            const snapshot = await db.collection('companies').get();
            const matches = [];
           
            snapshot.forEach(doc => {
                const company = doc.data();
                if (company.name.toLowerCase().includes(query)) {
                    matches.push({ id: doc.id, ...company });
                }
            });
           
            // Also search in mock data
            for (const category in mockCompanies) {
                mockCompanies[category].forEach(company => {
                    if (company.name.toLowerCase().includes(query)) {
                        // Check if not already in matches
                        if (!matches.some(m => m.id === company.id)) {
                            matches.push(company);
                        }
                    }
                });
            }
           
            if (matches.length === 0) {
                searchView.innerHTML = `
                    <div class="news-empty">
                        <i class="fa-regular fa-building" style="font-size: 2rem; margin-bottom: 10px;"></i>
                        <p>No companies found matching "${query}"</p>
                    </div>
                `;
                return;
            }
           
            let html = '';
            matches.forEach(company => {
                const phoneCount = company.phones?.length || 0;
                html += `
                    <div class="suggestion-card" onclick="showCompanyDetail('${company.id}')">
                        <i class="fa-solid fa-building" style="color: var(--primary-green);"></i>
                        <div>
                            <strong>${company.name}</strong>
                            <p style="font-size: 0.8rem; color: var(--grey);">${phoneCount} contact numbers</p>
                        </div>
                    </div>
                `;
            });
           
            searchView.innerHTML = html;
        } catch (error) {
            console.error('Search error:', error);
            searchView.innerHTML = '<div class="news-error">Search failed. Please try again.</div>';
        }
    }

    // =============================================
    // CONTACT FUNCTIONS
    // =============================================
    function makeCall(phone) {
        const cleanNumber = phone.replace(/\s/g, '');
        window.location.href = `tel:${cleanNumber}`;
    }

    function sendEmail(email) {
        window.location.href = `mailto:${email}`;
    }

    // =============================================
    // NAVIGATION
    // =============================================
    function setActive(element, view) {
        document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
        element.classList.add('active');
       
        // Handle navigation
        if (view === 'home') {
            hideCompaniesList();
            hideCompanyDetail();
            document.getElementById('home-view').classList.remove('hidden');
            document.getElementById('search-view').classList.add('hidden');
            searchInput.value = '';
            clearBtn.style.display = 'none';
            headerLogo.classList.remove('hidden');
        }
    }

    // =============================================
    // INITIALIZATION
    // =============================================
    document.addEventListener('DOMContentLoaded', () => {
        // Load news
        loadNewsFromFirebase(true);
       
        // Update connection status
        const statusEl = document.getElementById('connection-status');
        statusEl.innerHTML = '<i class="fa-solid fa-circle"></i> Ready';
        statusEl.className = 'connection-status status-connected';
       
        // Add some sample data to Firebase if empty (optional)
