    async function addSampleDataIfEmpty() {
        try {
            const snapshot = await db.collection('companies').limit(1).get();
            if (snapshot.empty) {
                console.log('No companies in Firebase, you can add them via admin panel');
                // Don't auto-add, let admin panel handle it
            }
        } catch (error) {
            console.log('Firebase not ready for sample data');
        }
    }
